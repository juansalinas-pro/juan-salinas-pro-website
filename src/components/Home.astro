---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Testimonials from '../components/Testimonials.astro'
import { Rocket, Cog, CheckCircle, Zap, Layers, TrendingUp, Target, Repeat, Clock, Award } from 'lucide-astro'

const metadata = {
  title: 'Juan Salinas - Software Engineer',
  description: 'Sitio Web profesional de Juan Salinas. Un ingeniero de software apasionado con más de una década de experiencia en Ingeniería de Software y startups.',
}
---

<html lang="en">
  <head>
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
  </head>
  <body class="flex flex-col min-h-screen bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <Header />
    <main class="flex-grow">
      <section class="pt-24 pb-12 bg-gradient-to-b from-white to-gray-100 dark:from-gray-900 dark:to-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
            <div class="mb-8 relative inline-block">
              <img
                src="/avatars/me.jpeg?height=300&width=300"
                alt="Juan Salinas"
                width={300}
                height={300}
                class="mx-auto rounded-full shadow-lg border-4 border-white dark:border-gray-800"
              />
              <div class="absolute inset-0 rounded-full shadow-inner"></div>
            </div>
            <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white sm:text-5xl md:text-6xl">
              <span class="block">Hola, Soy Juan Salinas</span>
              <span class="block text-indigo-600 dark:text-indigo-400">Ingeniero de Software</span>
            </h1>
            <p class="mt-3 max-w-md mx-auto text-base text-gray-600 dark:text-gray-300 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
              Construyo soluciones tecnológicas escalables e innovadoras, combinando más de 10 años de experiencia en ingeniería de software con una pasión por transformar ideas en impacto real.
            </p>
            <p class="mt-3 max-w-md mx-auto text-base text-gray-600 dark:text-gray-300 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
              Soy experto en sistemas de alto rendimiento y tecnologías de vanguardia, mi enfoque está en resolver desafíos de negocio con creatividad y eficiencia.
            </p>
          </div>
        </div>
      </section>
      <Testimonials />
    </main>
    <Footer />
  </body>
</html>
